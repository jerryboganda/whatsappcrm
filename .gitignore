# Large binary update file (not needed for dev)
core_update.b64

# Laravel runtime/generated files (production churn)
/core/storage/logs/*.log
/core/storage/debugbar/*.json
/core/storage/framework/sessions/*
!/core/storage/framework/sessions/.gitignore
/core/storage/framework/views/*.php
!/core/storage/framework/views/.gitignore
/core/storage/framework/cache/data/**
!/core/storage/framework/cache/.gitignore
/core/bootstrap/cache/*.php
!/core/bootstrap/cache/.gitignore

# Local-only deploy helpers and artifacts
/.htaccess
/router.php
/CON
/NUL
/*.sql
/core/.env.bak*
/core/*Feature_Documentation*.pdf
/core/*Feature_Breakdown*.pdf
/core/admin_menu_snapshot.json
/core/feature_list_raw.txt
/core/user_sidebar_snapshot.blade.php
